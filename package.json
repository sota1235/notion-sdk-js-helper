{
  "name": "@sota1235/notion-sdk-js-helper",
  "version": "4.0.6",
  "description": "Helper utilities for using @notion/client",
  "type": "module",
  "packageManager": "npm@11.17.0",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "dependencies": {
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:publish": "tsc -p ./tsconfig.publish.json",
    "watch": "tsc --watch",
    "fix": "npm run lint -- --write",
    "lint": "npx @biomejs/biome check",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "notion"
  ],
  "author": "@sota1235",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sota1235/notion-sdk-js-helper.git"
  },
  "lint-staged": {
    "*.ts": [
      "npm run fix"
    ]
  },
  "peerDependencies": {
    "@notionhq/client": "5.x"
  }
}
